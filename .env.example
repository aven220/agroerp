# Database
DATABASE_URL=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=public
DATABASE_URL_BPMS=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=bpms
DATABASE_URL_EIP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eip
DATABASE_URL_EINT=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eint
DATABASE_URL_EOPS=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eops
DATABASE_URL_EATP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eatp
DATABASE_URL_EAPP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eapp
DATABASE_URL_EIWP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eiwp
DATABASE_URL_EPHP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=ephp
DATABASE_URL_EATR=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eatr
DATABASE_URL_EACC=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eacc
DATABASE_URL_EFFM=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=effm
DATABASE_URL_EAIP=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eaip
DATABASE_URL_EACE=postgresql://agroerp:agroerp_secret@localhost:5432/agroerp?schema=eace

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3080
API_PREFIX=api/v1
FRONTEND_PORT=5173

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=agroerp
S3_SECRET_KEY=agroerp_secret
S3_BUCKET=agroerp-files
S3_REGION=us-east-1

