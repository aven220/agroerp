<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nav_effm"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/effm_sync_status" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/qrInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/effm_qr_hint" />

    <Button
        android:id="@+id/btnQr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/effm_scan_qr" />

    <EditText
        android:id="@+id/machineInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/effm_machine_hint" />

    <Button
        android:id="@+id/btnStartOp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/effm_start_operation" />

    <EditText
        android:id="@+id/fuelInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/effm_fuel_hint"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/btnFuel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/effm_record_fuel" />

    <EditText
        android:id="@+id/incidentInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/effm_incident_hint" />

    <Button
        android:id="@+id/btnIncident"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/effm_record_incident" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/effm_assignments_label"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/assignmentsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="13sp" />
</LinearLayout>
