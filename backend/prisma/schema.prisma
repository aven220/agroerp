  @@index([organizationId, requestedAt])
  @@index([organizationId, clientId])
  @@index([organizationId, moduleRef])
  @@map("api_request_logs")
}

model ApiCircuitBreakerState {
  id             String          @id @default(uuid()) @db.Uuid
