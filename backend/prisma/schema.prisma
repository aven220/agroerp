  metadata              Json           @default("{}")
  aiReadiness           Json           @default("{}") @map("ai_readiness")
  version               Int            @default(1)
  externalId            String?        @map("external_id") @db.VarChar(255)
  syncStatus            ResourceSyncStatus @default(synced) @map("sync_status")
  registeredAt          DateTime       @default(now()) @map("registered_at") @db.Timestamptz
  activatedAt           DateTime?      @map("activated_at") @db.Timestamptz
  lastGeometryChangeAt  DateTime?      @map("last_geometry_change_at") @db.Timestamptz
  lastVisitAt           DateTime?      @map("last_visit_at") @db.Timestamptz
  createdBy             String?        @map("created_by") @db.Uuid
  updatedBy             String?        @map("updated_by") @db.Uuid
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?      @map("deleted_at") @db.Timestamptz

  organization          Organization            @relation(fields: [organizationId], references: [id])
  parcels               FarmParcel[]
  lots                  FarmLot[]
  geometries            TerritoryGeometry[]
  geometryRevisions     GeometryRevision[]
  producerLinks         ProducerTerritoryLink[]
  documents             TerritoryDocument[]
  certifications        TerritoryCertification[]
  naturalResources      NaturalResourceFeature[]
  infrastructure        InfrastructureFeature[]
  risks                 TerritoryRiskAssessment[]
  lifecycleEvents       FarmLifecycleEvent[]
  cropStands            CropStand[]
  visitLinks            TerritoryVisitLink[]
  geographicAttributes  GeographicAttribute[]
  digitalTwin           FarmDigitalTwin?
  kpiSnapshots          TerritoryKpiSnapshot[]
  aiInsights            FarmAiInsight[]
  fieldLotProfiles      FieldLotProfile[]

  @@unique([organizationId, farmCode])
  @@unique([organizationId, externalId])
  @@index([organizationId, status])
  @@index([organizationId, municipalityCode])
  @@index([organizationId, deletedAt])
  @@index([organizationId, syncStatus])
  @@map("farm_units")
