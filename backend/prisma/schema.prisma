// ─── EAMIP — Enterprise API Management & Integration Platform ─────────────────

enum ApiDefinitionStatus {
  draft
  published
  deprecated
  unpublished
}

enum ApiAuthType {
  none
  api_key
  oauth2
  jwt
  oidc
}

enum ApiClientStatus {
  active
  suspended
  revoked
}

enum ApiConnectorType {
  dian
  bank
  payment_gateway
  email
  sms
  whatsapp
  gis
  weather
  external_erp
  crm
  iot
  auth_provider
  custom
}

enum ApiHealthStatus {
  healthy
  degraded
  down
  unknown
}

enum ApiBreakerState {
  closed
  open
  half_open
}

model ApiDefinition {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  apiKey         String              @map("api_key") @db.VarChar(100)
  name           String              @db.VarChar(255)
  description    String?             @db.Text
  domain         String              @default("core") @db.VarChar(80)
  tags           String[]            @default([])
  status         ApiDefinitionStatus @default(draft)
  basePath       String              @map("base_path") @db.VarChar(255)
  moduleRef      String              @map("module_ref") @db.VarChar(80)
  authType       ApiAuthType         @default(api_key) @map("auth_type")
  isPublic       Boolean             @default(false) @map("is_public")
  openApiSpec    Json                @default("{}") @map("open_api_spec")
  corsConfig     Json                @default("{}") @map("cors_config")
  metadata       Json                @default("{}")
  publishedAt    DateTime?           @map("published_at") @db.Timestamptz
  deprecatedAt   DateTime?           @map("deprecated_at") @db.Timestamptz
  createdBy      String?             @map("created_by") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  versions     ApiVersion[]
  routes       ApiRoute[]
  requestLogs  ApiRequestLog[]

  @@unique([organizationId, apiKey])
  @@index([organizationId, status, domain])
  @@map("api_definitions")
}

model ApiVersion {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  apiDefinitionId String             @map("api_definition_id") @db.Uuid
  version        String              @db.VarChar(30)
  status         ApiDefinitionStatus @default(draft)
  changelog      String?             @db.Text
  openApiSpec    Json                @default("{}") @map("open_api_spec")
  publishedAt    DateTime?           @map("published_at") @db.Timestamptz
  deprecatedAt   DateTime?           @map("deprecated_at") @db.Timestamptz
  createdBy      String?             @map("created_by") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id])
  apiDefinition ApiDefinition @relation(fields: [apiDefinitionId], references: [id], onDelete: Cascade)
  routes        ApiRoute[]

  @@unique([apiDefinitionId, version])
  @@map("api_versions")
}

model ApiRoute {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  apiDefinitionId    String   @map("api_definition_id") @db.Uuid
  apiVersionId       String?  @map("api_version_id") @db.Uuid
  routeKey           String   @map("route_key") @db.VarChar(120)
  method             String   @db.VarChar(10)
  path               String   @db.VarChar(500)
  upstreamPath       String   @map("upstream_path") @db.VarChar(500)
  moduleRef          String   @map("module_ref") @db.VarChar(80)
  timeoutMs          Int      @default(30000) @map("timeout_ms")
  retryCount         Int      @default(2) @map("retry_count")
  loadBalanceStrategy String  @default("round_robin") @map("load_balance_strategy") @db.VarChar(30)
  weight             Int      @default(100)
  isActive           Boolean  @default(true) @map("is_active")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization   @relation(fields: [organizationId], references: [id])
  apiDefinition ApiDefinition  @relation(fields: [apiDefinitionId], references: [id], onDelete: Cascade)
  apiVersion    ApiVersion?    @relation(fields: [apiVersionId], references: [id], onDelete: SetNull)
  circuitBreakers ApiCircuitBreakerState[]

  @@unique([apiDefinitionId, routeKey])
  @@index([organizationId, isActive])
  @@map("api_routes")
}

model ApiClient {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @map("organization_id") @db.Uuid
  clientKey         String          @map("client_key") @db.VarChar(100)
  name              String          @db.VarChar(255)
  description       String?         @db.Text
  status            ApiClientStatus @default(active)
  ownerUserId       String?         @map("owner_user_id") @db.Uuid
  scopes            String[]        @default([])
  rateLimitPerMinute Int            @default(120) @map("rate_limit_per_minute")
  rateLimitPerDay    Int            @default(50000) @map("rate_limit_per_day")
  whitelistIps       String[]       @default([]) @map("whitelist_ips")
  blacklistIps       String[]       @default([]) @map("blacklist_ips")
  metadata           Json            @default("{}")
  createdBy          String?         @map("created_by") @db.Uuid
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  keys         ApiClientKey[]
  requestLogs  ApiRequestLog[]

  @@unique([organizationId, clientKey])
  @@map("api_clients")
}

model ApiClientKey {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  keyHash        String   @map("key_hash") @db.VarChar(255)
  keyPrefix      String   @map("key_prefix") @db.VarChar(20)
  name           String   @db.VarChar(255)
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  client       ApiClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId, keyPrefix])
  @@map("api_client_keys")
}

model ApiConnector {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  connectorKey   String           @map("connector_key") @db.VarChar(100)
  connectorType  ApiConnectorType @map("connector_type")
  name           String           @db.VarChar(255)
  description    String?          @db.Text
  baseUrl        String?          @map("base_url") @db.VarChar(500)
