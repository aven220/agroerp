  photoContentId       String?                 @map("photo_content_id") @db.Uuid
  signatureContentId   String?                 @map("signature_content_id") @db.Uuid
  taxRegimeCode        String?                 @map("tax_regime_code") @db.VarChar(50)
  paymentPreferenceCode String?                @map("payment_preference_code") @db.VarChar(50)
  assignedBuyerId      String?                 @map("assigned_buyer_id") @db.Uuid
  assignedTechnicianId String?                 @map("assigned_technician_id") @db.Uuid
  riskScore            Int                     @default(0) @map("risk_score")
  qualityScore         Int                     @default(0) @map("quality_score")
  lifetimeValueScore   Decimal?                @map("lifetime_value_score") @db.Decimal(18, 2)
