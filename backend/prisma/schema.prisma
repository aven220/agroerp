  voided
}

enum EfmApInvoiceType {
  standard
  credit_note
  debit_note
  advance
}

enum EfmApPayableStatus {
  open
  partial
  paid
  overdue
  voided
  on_hold
}

enum EfmApPaymentStatus {
  draft
  scheduled
  pending_approval
  approved
  rejected
  processed
  voided
}

enum EfmApBatchStatus {
  draft
  scheduled
  pending_approval
  approved
  processing
  completed
  voided
}

enum EfmApScheduleStatus {
  planned
