model AiProviderConfig {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  providerKey    String         @map("provider_key") @db.VarChar(50)
  providerType   AiProviderType @map("provider_type")
  name           String         @db.VarChar(255)
  isDefault      Boolean        @default(false) @map("is_default")
  isActive       Boolean        @default(true) @map("is_active")
  baseUrl        String?        @map("base_url") @db.VarChar(500)
  apiKeyRef      String?        @map("api_key_ref") @db.VarChar(255)
  settings       Json           @default("{}")
  rateLimits     Json           @default("{}") @map("rate_limits")
  metadata       Json           @default("{}")
  createdBy      String?        @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  models       AiModelDefinition[]

  @@unique([organizationId, providerKey])
  @@index([organizationId, isActive, isDefault])
  @@map("ai_provider_configs")
}

model AiModelDefinition {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  providerId     String         @map("provider_id") @db.Uuid
  modelKey       String         @map("model_key") @db.VarChar(100)
  displayName    String         @map("display_name") @db.VarChar(255)
  modelType      String         @default("chat") @map("model_type") @db.VarChar(50)
  capabilities   String[]       @default([])
  contextWindow  Int            @default(8192) @map("context_window")
  costPer1kIn    Decimal?       @map("cost_per_1k_in") @db.Decimal(10, 6)
  costPer1kOut   Decimal?       @map("cost_per_1k_out") @db.Decimal(10, 6)
  isDefault      Boolean        @default(false) @map("is_default")
  isActive       Boolean        @default(true) @map("is_active")
  settings       Json           @default("{}")
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization     @relation(fields: [organizationId], references: [id])
  provider     AiProviderConfig   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, modelKey])
  @@index([organizationId, isActive])
  @@map("ai_model_definitions")
}

model AiPromptTemplate {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  promptKey      String         @map("prompt_key") @db.VarChar(100)
  name           String         @db.VarChar(255)
  description    String?        @db.Text
  serviceType    AiServiceType  @default(chat) @map("service_type")
  status         AiPromptStatus @default(draft)
  variables      Json           @default("[]")
  metadata       Json           @default("{}")
  createdBy      String?        @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [organizationId], references: [id])
  versions     AiPromptVersion[]

  @@unique([organizationId, promptKey])
  @@index([organizationId, status])
  @@map("ai_prompt_templates")
}

model AiPromptVersion {
  id          String         @id @default(uuid()) @db.Uuid
  templateId  String         @map("template_id") @db.Uuid
  version     Int
  status      AiPromptStatus @default(draft)
  template    String         @db.Text
  systemPrompt String?       @map("system_prompt") @db.Text
  changelog   String?        @db.Text
  testResults Json           @default("{}") @map("test_results")
  approvedBy  String?        @map("approved_by") @db.Uuid
  approvedAt  DateTime?      @map("approved_at") @db.Timestamptz
  publishedAt DateTime?      @map("published_at") @db.Timestamptz
  createdBy   String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  promptTemplate AiPromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("ai_prompt_versions")
}

model AiCopilotDefinition {
