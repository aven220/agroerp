  altitudeMaxM          Int?           @map("altitude_max_m")
  avgSlopePct           Decimal?       @map("avg_slope_pct") @db.Decimal(6, 2)
  tenureTypeCode        String?        @map("tenure_type_code") @db.VarChar(50)
