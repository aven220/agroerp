// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  email          String     @db.VarChar(255)
  passwordHash   String?    @map("password_hash") @db.VarChar(255)
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String     @map("last_name") @db.VarChar(100)
  userType       UserType   @default(internal) @map("user_type")
  status         UserStatus @default(active)
  phone          String?    @db.VarChar(50)
  locale         String     @default("es") @db.VarChar(10)
  timezone       String     @default("America/Bogota") @db.VarChar(50)
  avatarFileId   String?    @map("avatar_file_id") @db.Uuid
  signatureFileId String?   @map("signature_file_id") @db.Uuid
  preferences    Json       @default("{}")
  profile        Json       @default("{}")
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz
  lockedAt       DateTime?  @map("locked_at") @db.Timestamptz
  lockedReason   String?    @map("locked_reason") @db.Text
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz
  mustChangePassword Boolean @default(false) @map("must_change_password")
  failedLoginAttempts Int   @default(0) @map("failed_login_attempts")
  mfaEnabled     Boolean    @default(false) @map("mfa_enabled")
  expiresAt      DateTime?  @map("expires_at") @db.Timestamptz
  metadata       Json       @default("{}")
  version        Int        @default(1)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  userRoles       UserRole[]
  userGroups      UserGroup[]
  teamMembers     TeamMember[]
  userScopes      UserScope[]
  sessions        Session[]
  delegationsFrom Delegation[] @relation("Delegator")
  delegationsTo   Delegation[] @relation("Delegate")
  substitutionsFrom Substitution[] @relation("SubstitutedUser")
  substitutionsAs Substitution[] @relation("SubstituteUser")
  auditLogs       AuditLog[]
  devices         Device[]
  serviceAccounts ServiceAccount[]
  iamMfaFactors   IamMfaFactor[]
  iamWebAuthnCredentials IamWebAuthnCredential[]
  iamPasswordHistories IamPasswordHistory[]
  iamTemporaryRoles IamTemporaryRole[]
  iamAuthAttempts IamAuthAttempt[]
  iamSecurityEvents IamSecurityEvent[]
  iamAnomalyAlerts IamAnomalyAlert[]
  notificationMessages       NotificationMessage[] @relation("NotificationRecipient")
  notificationAssigned       NotificationMessage[] @relation("NotificationAssignee")
  notificationSchedules      NotificationSchedule[]
  notificationDeviceTokens   NotificationDeviceToken[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, userType])
  @@map("users")
}

// ─── Access Control (RBAC) ───────────────────────────────────────────────────

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(100)
  slug           String   @db.VarChar(100)
  description    String?  @db.Text
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization     @relation(fields: [organizationId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  roleGroups      RoleGroup[]
  iamRoleVersions IamRoleVersion[]
  iamTemporaryRoles IamTemporaryRole[]

  @@unique([organizationId, slug])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  scope       String  @default("org") @db.VarChar(50)
  description String? @db.Text
  moduleId    String? @map("module_id") @db.VarChar(100)

  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Policy {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  description    String?      @db.Text
  effect         PolicyEffect
  resource       String?      @db.VarChar(100)
  action         String?      @db.VarChar(50)
  subject        Json         @default("{}")
  conditions     Json         @default("{}")
  priority       Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, active, priority])
  @@map("policies")
}

// ─── Identity Engine extensions ──────────────────────────────────────────────

model OrgUnit {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  parentId       String?      @map("parent_id") @db.Uuid
  type           OrgUnitType
  name           String       @db.VarChar(255)
  code           String       @db.VarChar(50)
  metadata       Json         @default("{}")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       OrgUnit?     @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children     OrgUnit[]    @relation("OrgUnitHierarchy")
  teams        Team[]
  userScopes   UserScope[]

  @@unique([organizationId, code])
  @@index([organizationId, type])
  @@map("org_units")
}

model Group {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(255)
  slug           String    @db.VarChar(100)
  description    String?   @db.Text
  type           GroupType @default(security)
  metadata       Json      @default("{}")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  userGroups   UserGroup[]
  roleGroups   RoleGroup[]

  @@unique([organizationId, slug])
  @@map("groups")
}

model UserGroup {
  userId     String   @map("user_id") @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

model RoleGroup {
  roleId  String @map("role_id") @db.Uuid
  groupId String @map("group_id") @db.Uuid

  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([roleId, groupId])
  @@map("role_groups")
}

model Team {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  orgUnitId      String?  @map("org_unit_id") @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @db.VarChar(100)
  leaderId       String?  @map("leader_id") @db.Uuid
  metadata       Json     @default("{}")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  orgUnit      OrgUnit?     @relation(fields: [orgUnitId], references: [id])
  members      TeamMember[]

  @@unique([organizationId, slug])
  @@map("teams")
}

model TeamMember {
  teamId   String @map("team_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  role     String @default("member") @db.VarChar(50)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

model UserScope {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  scopeType  String   @map("scope_type") @db.VarChar(50)
  scopeId    String   @map("scope_id") @db.Uuid
  orgUnitId  String?  @map("org_unit_id") @db.Uuid
  grantedBy  String?  @map("granted_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgUnit OrgUnit? @relation(fields: [orgUnitId], references: [id])

  @@index([userId, scopeType])
  @@index([scopeType, scopeId])
  @@map("user_scopes")
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  deviceId         String?       @map("device_id") @db.Uuid
  status           SessionStatus @default(active)
  ipAddress        String?       @map("ip_address") @db.VarChar(45)
  userAgent        String?       @map("user_agent") @db.Text
  refreshTokenHash String?       @map("refresh_token_hash") @db.VarChar(255)
  jti              String?       @db.VarChar(100)
  lastActivityAt   DateTime      @default(now()) @map("last_activity_at") @db.Timestamptz
  expiresAt        DateTime      @map("expires_at") @db.Timestamptz
  revokedAt        DateTime?     @map("revoked_at") @db.Timestamptz
  revokedReason    String?       @map("revoked_reason") @db.Text
  metadata         Json          @default("{}")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([jti])
  @@map("sessions")
}

model Delegation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  delegatorId    String   @map("delegator_id") @db.Uuid
  delegateId     String   @map("delegate_id") @db.Uuid
  permissions    Json     @default("[]")
  scopes         Json     @default("{}")
  startsAt       DateTime @map("starts_at") @db.Timestamptz
  endsAt         DateTime @map("ends_at") @db.Timestamptz
  active         Boolean  @default(true)
  reason         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  delegator User @relation("Delegator", fields: [delegatorId], references: [id])
  delegate  User @relation("Delegate", fields: [delegateId], references: [id])

  @@index([organizationId, delegateId, active])
  @@map("delegations")
}

model Substitution {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  substituteId   String   @map("substitute_id") @db.Uuid
  roleSlugs      Json     @default("[]") @map("role_slugs")
  startsAt       DateTime @map("starts_at") @db.Timestamptz
  endsAt         DateTime @map("ends_at") @db.Timestamptz
