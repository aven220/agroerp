}

model ApiRequestLog {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  clientId        String?  @map("client_id") @db.Uuid
  apiDefinitionId String?  @map("api_definition_id") @db.Uuid
  routeKey        String?  @map("route_key") @db.VarChar(120)
  method          String   @db.VarChar(10)
  path            String   @db.VarChar(500)
  statusCode      Int      @map("status_code")
  latencyMs       Int      @map("latency_ms")
  moduleRef       String?  @map("module_ref") @db.VarChar(80)
  errorMessage    String?  @map("error_message") @db.Text
  requestedAt     DateTime @default(now()) @map("requested_at") @db.Timestamptz

  organization  Organization   @relation(fields: [organizationId], references: [id])
  client        ApiClient?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
