  tags                 String[]                @default([])
  metadata             Json                    @default("{}")
  goldenRecordVersion  Int                     @default(1) @map("golden_record_version")
  version              Int                     @default(1)
  externalId           String?                 @map("external_id") @db.VarChar(255)
  syncStatus           ResourceSyncStatus      @default(synced) @map("sync_status")
  registeredAt         DateTime                @default(now()) @map("registered_at") @db.Timestamptz
  activatedAt          DateTime?               @map("activated_at") @db.Timestamptz
  lastActivityAt       DateTime?               @map("last_activity_at") @db.Timestamptz
  lastVisitAt          DateTime?               @map("last_visit_at") @db.Timestamptz
  createdBy            String?                 @map("created_by") @db.Uuid
  updatedBy            String?                 @map("updated_by") @db.Uuid
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime                @updatedAt @map("updated_at") @db.Timestamptz
