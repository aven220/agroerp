enum HcmRcVacancyStatus {
  draft
  pending_approval
  approved
  published_internal
  published_external
  open
  in_selection
  offer_stage
  filled
  closed
  cancelled
}

enum HcmRcApprovalStatus {
  pending
  approved
  rejected
}

enum HcmRcCandidateStatus {
  new
  screening
  interview
  assessment
  offer
  hired
  rejected
  withdrawn
  talent_pool
}

enum HcmRcApplicationStatus {
  applied
  screening
  interview
  assessment
  shortlisted
  offer
  hired
  rejected
  withdrawn
}

enum HcmRcInterviewStatus {
  scheduled
  completed
  cancelled
