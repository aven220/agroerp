  lastRunAt        DateTime?        @map("last_run_at") @db.Timestamptz
  eventTypes       String[]         @default([]) @map("event_types")
  dependencies     String[]         @default([])
  maxRetries       Int              @default(3) @map("max_retries")
  retryStrategy    EsdjeRetryStrategy @default(exponential) @map("retry_strategy")
  retryDelayMs     Int              @default(1000) @map("retry_delay_ms")
  timeoutMs        Int              @default(300000) @map("timeout_ms")
  priority         Int              @default(100)
  parallelism      Int              @default(1)
  businessDaysOnly Boolean          @default(false) @map("business_days_only")
