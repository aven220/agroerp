  primaryLanguageCode  String?                 @map("primary_language_code") @db.VarChar(50)
  educationLevelCode   String?                 @map("education_level_code") @db.VarChar(50)
  ethnicGroupCode      String?                 @map("ethnic_group_code") @db.VarChar(50)
  lifecycleStatus      ProducerLifecycleStatus @default(draft) @map("lifecycle_status")
