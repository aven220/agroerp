  @@index([organizationId, municipalityCode])
  @@index([organizationId, assignedBuyerId])
  @@index([organizationId, assignedTechnicianId])
  @@index([organizationId, syncStatus])
  @@index([organizationId, deletedAt])
  @@map("producers")
}

