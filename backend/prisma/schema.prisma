model AiMemoryEntry {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  memoryKey      String   @map("memory_key") @db.VarChar(100)
