  indefinite
  fixed_term
  work_order
  apprenticeship
  contractor
  intern
}

enum HcmContractStatus {
  draft
  active
  extended
  renewed
  terminated
  expired
}

enum HcmDocumentType {
  contract
  certification
  identity
  degree
  course
  license
  permit
  signature
  photo
  other
}

enum HcmHistoryEventType {
  hire
  transfer
  promotion
  demotion
  leave
  return
  termination
  contract_change
  salary_change
  position_change
