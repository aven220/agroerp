// ─── ESDJE — Enterprise Scheduler & Distributed Job Engine ───────────────────

enum EsdjeJobType {
  one_time
  recurring
  scheduled
  deferred
  event
  manual
  distributed
  parallel
  dependent
}

enum EsdjeJobStatus {
  pending
  queued
  running
  completed
  failed
  cancelled
  dead_letter
  paused
}

enum EsdjeQueuePriority {
  critical
  high
  normal
  low
}

enum EsdjeRetryStrategy {
  exponential
  linear
  fixed
}

enum EsdjeWorkerStatus {
  online
  offline
  draining
  busy
}

model EsdjeJobQueue {
  id             String             @id @default(uuid()) @db.Uuid
