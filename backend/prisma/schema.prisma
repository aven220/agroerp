  payload          Json             @default("{}")
  schedule         Json             @default("{}")
  cronExpression   String?          @map("cron_expression") @db.VarChar(100)
  timezone         String           @default("America/Bogota") @db.VarChar(50)
  runAt            DateTime?        @map("run_at") @db.Timestamptz
