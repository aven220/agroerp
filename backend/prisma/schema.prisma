enum EfmTrAccountType {
  checking
  savings
}

enum EfmTrCashBoxType {
  general
  petty
}

enum EfmTrCashSessionStatus {
  open
  closed
  pending_approval
}

enum EfmTrCashCountStatus {
  draft
  submitted
  approved
  rejected
}

enum EfmTrMovementType {
  transfer
  deposit
  withdrawal
  internal
  ap_payment
  ar_collection
  adjustment
}

enum EfmTrMovementStatus {
  draft
  pending_approval
  approved
  processed
  voided
}

enum EfmTrStatementStatus {
  imported
  reconciling
  reconciled
  voided
}

enum EfmTrReconciliationStatus {
