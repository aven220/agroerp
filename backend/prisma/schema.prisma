  resourceType   String?                @map("resource_type") @db.VarChar(100)
  currentState   String                 @map("current_state") @db.VarChar(100)
  status         WorkflowInstanceStatus @default(active)
  context        Json                   @default("{}")
  priority       String                 @default("normal") @db.VarChar(20)
  dueAt          DateTime?              @map("due_at") @db.Timestamptz
  startedBy      String?                @map("started_by") @db.Uuid
  startedAt      DateTime               @default(now()) @map("started_at") @db.Timestamptz
  completedAt    DateTime?              @map("completed_at") @db.Timestamptz
  suspendedAt    DateTime?              @map("suspended_at") @db.Timestamptz
  suspendedBy    String?                @map("suspended_by") @db.Uuid
  externalId     String?                @map("external_id") @db.VarChar(255)
  syncStatus     ResourceSyncStatus     @default(synced) @map("sync_status")
  version        Int                    @default(1)
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz

