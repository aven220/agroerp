# Copy to local.properties (gitignored) for device-specific overrides.
# Emulator → 10.0.2.2 maps to host localhost.
# Physical device → use your machine LAN IP.

sdk.dir=/path/to/Android/sdk
AGROERP_API_BASE_URL=http://10.0.2.2:3080/api/v1/

# Example for physical device on same Wi‑Fi:
# AGROERP_API_BASE_URL=http://192.168.1.50:3080/api/v1/
