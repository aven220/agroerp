# Copiar a la raíz del proyecto en el servidor: cp infra/env.production.example .env
# Ajuste contraseñas y secretos antes de producción.

# ─── Servidor (HTTPS) ───
SERVER_IP=20.231.96.53
PUBLIC_URL=https://20.231.96.53
NODE_ENV=production
PORT=3080
API_PREFIX=api/v1
FRONTEND_URL=https://20.231.96.53
CORS_ORIGIN=https://20.231.96.53

# ─── Base de datos (Docker interno) ───
POSTGRES_USER=agroerp
POSTGRES_PASSWORD=CAMBIE_ESTA_CONTRASEÑA_DB
POSTGRES_DB=agroerp

DATABASE_URL=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=public
DATABASE_URL_BPMS=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=bpms
DATABASE_URL_EIP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eip
DATABASE_URL_EINT=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eint
DATABASE_URL_EOPS=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eops
DATABASE_URL_EATP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eatp
DATABASE_URL_EAPP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eapp
DATABASE_URL_EIWP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eiwp
DATABASE_URL_EPHP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=ephp
DATABASE_URL_EATR=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eatr
DATABASE_URL_EACC=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eacc
DATABASE_URL_EFFM=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=effm
DATABASE_URL_EAIP=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eaip
DATABASE_URL_EACE=postgresql://agroerp:CAMBIE_ESTA_CONTRASEÑA_DB@postgres:5432/agroerp?schema=eace

REDIS_URL=redis://redis:6379

# ─── JWT (generar cadenas largas aleatorias) ───
JWT_SECRET=CAMBIE_JWT_SECRET_LARGO_ALEATORIO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CAMBIE_REFRESH_SECRET_LARGO
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO / archivos ───
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=agroerp
S3_SECRET_KEY=CAMBIE_MINIO_SECRET
S3_BUCKET=agroerp-files
S3_REGION=us-east-1

# ─── URLs de acceso (HTTPS) ───
# Antes del primer deploy: bash scripts/setup-ssl.sh selfsigned
# Web ERP:     https://20.231.96.53/
# API health:  https://20.231.96.53/api/v1/health
# Swagger:     https://20.231.96.53/docs
# App Android: https://20.231.96.53/api/v1/
